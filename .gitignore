# Terraform state files — never commit these!
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files with secrets
terraform.tfvars
*.auto.tfvars

# Terraform directories
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Azure credentials
.azure/
*.pem
*.key
